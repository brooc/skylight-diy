# App
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://daymark:daymark@localhost:5432/daymark

# Session
SESSION_COOKIE_NAME=daymark_session
SESSION_SECRET=replace-with-local-dev-secret

# Token encryption
# Generate with: openssl rand -base64 32
# Keep this value with your database backups. Changing it makes stored Google tokens unreadable.
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-base64-key

# Google OAuth
# See docs/google-calendar-setup.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# Calendar cache
CALENDAR_CACHE_FRESH_TTL_SECONDS=300
CALENDAR_CACHE_STALE_TTL_SECONDS=86400
