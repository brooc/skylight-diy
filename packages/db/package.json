{
  "name": "@skylight-diy/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --check .",
    "test": "echo \"No tests yet\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@skylight-diy/config": "workspace:*",
    "drizzle-orm": "^0.35.3",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.26.2",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
