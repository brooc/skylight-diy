{
  "name": "@daymark/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "dev:docker": "tsx watch --clear-screen=false src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@daymark/config": "workspace:*",
    "@daymark/db": "workspace:*",
    "drizzle-orm": "^0.35.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
